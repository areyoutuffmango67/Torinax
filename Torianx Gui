        local strips=16
        for si=1,strips do
            local vv=1-(si-1)/(strips-1)
            self:_Draw(wid.."_sv_"..si,"Square",{Position=palPos+Vector2.new(0,(si-1)*(palH/strips)),Size=Vector2.new(palW,palH/strips+1),Color=hsvToRgb(item.h,item.s,vv),ZIndex=62})
        end
        -- Saturation overlay (gradient from grey)
        for si=1,strips do
            local ss=(si-1)/(strips-1)
            local c=Color3.fromRGB(140,140,140)
            local f=Instance.new -- we just draw an overlay using transparency
            -- Omit: multi-layer gradient is expensive; the V-axis strip is enough
            self:_Undraw(wid.."_svo_"..si)
        end
        local cX=palPos.X+item.s*palW; local cY=palPos.Y+(1-item.v)*palH
        self:_Draw(wid.."_svch_h","Square",{Position=Vector2.new(palPos.X,cY-1),Size=Vector2.new(palW,2),Color=Color3.new(1,1,1),ZIndex=64})
        self:_Draw(wid.."_svch_v","Square",{Position=Vector2.new(cX-1,palPos.Y),Size=Vector2.new(2,palH),Color=Color3.new(1,1,1),ZIndex=64})
        -- Cursor dot
        self:_Draw(wid.."_svdot","Circle",{Position=Vector2.new(cX-5,cY-5),Size=Vector2.new(10,10),Color=Color3.new(1,1,1),ZIndex=65})
        -- Hue bar
        local hueH=10; local huePos=Vector2.new(wx,wy+24+palH+6); local hSegs=24
        for hi=1,hSegs do
            self:_Draw(wid.."_h_"..hi,"Square",{Position=huePos+Vector2.new((hi-1)*(innerW/hSegs),0),Size=Vector2.new(innerW/hSegs+1,hueH),Color=hsvToRgb((hi-1)/hSegs,1,1),ZIndex=62})
        end
        local hcX=huePos.X+item.h*innerW
        self:_Draw(wid.."_hcur","Square",{Position=Vector2.new(hcX-2,huePos.Y-1),Size=Vector2.new(4,hueH+2),Filled=false,Color=T.Text,Thickness=1,ZIndex=64})
        self:_Draw(wid.."_palb","Square",{Position=palPos,Size=Vector2.new(palW,palH),Filled=false,Color=T.Border1,Thickness=1,ZIndex=63})
        if Input.click and over(palPos,Vector2.new(palW,palH)) then item.dragSV=true end
        if Input.click and over(huePos,Vector2.new(innerW,hueH)) then item.dragH=true end
        if not Input.held then item.dragSV=false; item.dragH=false end
        if item.dragSV then local m=mpos(); item.s=clamp((m.X-palPos.X)/palW,0,1); item.v=1-clamp((m.Y-palPos.Y)/palH,0,1); item.value=hsvToRgb(item.h,item.s,item.v); pcall(item.cb,item.value) end
        if item.dragH then item.h=clamp((mpos().X-huePos.X)/innerW,0,1); item.value=hsvToRgb(item.h,item.s,item.v); pcall(item.cb,item.value) end
    end

    -- ── Config Manager Widget ────────────────────────────────────────────────
    --  Layout (y relative to widget top):
    --    0  : "Saved Configs" label + [↻] refresh btn
    --   16  : Config selection dropdown (22px)
    --   46  : "Config Name" label
    --   58  : Name text input (22px)
    --   88  : [Save]  [Overwrite]  row 1 (24px each)
    --  118  : [Delete][Auto Load]  row 2 (24px each)
    --  148  : END
    function WIN:_renderConfigManager(item,wid,wx,wy,innerW,FONT)
        -- One-time initialisation
        if not item._init then
            item._init=true
            item._cfgList = listSavedConfigs()
            item._autoload= getAutoloadName()
            -- Sub-item that plugs into the main dropdown system
            item._ddItem = {
                options   = item._cfgList,
                value     = "",
                maxVisible= 6,
                scroll    = 0,
                _selfId   = {},   -- unique identity key
                _wasM1    = false,
                _clicked  = false,
                _scrDrag  = false,
                cb = function(v)
                    item._nameInput = v
                end,
            }
            item._nameInput  = ""
            item._textFocused= false
            item._lastM1     = false
        end

        local DDI = item._ddItem
        local m1  = Input.held

        -- ── Row 0: label + refresh ──────────────────────────────
        self:_Draw(wid.."_lbl0","Text",{Position=Vector2.new(wx,wy),Text="Saved Configs",Size=11,Font=FONT,Color=T.SubText,ZIndex=6})

        local rfW=68; local rfPos=Vector2.new(wx+innerW-rfW,wy-1); local rfSz=Vector2.new(rfW,15)
        local rfHov=over(rfPos,rfSz)
        self:_Draw(wid.."_rfbg","RoundSquare",{Position=rfPos,Size=rfSz,Color=rfHov and T.Surface1 or T.Surface0,ZIndex=6})
        self:_Draw(wid.."_rfb", "RoundSquare",{Position=rfPos,Size=rfSz,Filled=false,Color=rfHov and T.Accent or T.Border0,Thickness=1,ZIndex=7})
        self:_Draw(wid.."_rft", "Text",{Position=rfPos+Vector2.new(rfW/2,8),Text="↻ Refresh",Size=11,Font=FONT,Color=rfHov and T.Accent or T.SubText,Center=true,ZIndex=7})

        if Input.click and not self._blockClicks and rfHov then
            item._cfgList    = listSavedConfigs()
            DDI.options      = item._cfgList
            item._autoload   = getAutoloadName()
            -- Clear selection if the config no longer exists
            local found=false
            for _,n in ipairs(item._cfgList) do if n==DDI.value then found=true; break end end
            if not found then DDI.value=""; item._nameInput="" end
        end

        -- ── Row 1: Config selection dropdown ───────────────────
        local ddY   = wy+16
        local ddPos = Vector2.new(wx,ddY); local ddSz=Vector2.new(innerW,22)
        local isOpen= (self._openDropId==DDI._selfId)
        local dispV = (DDI.value~="" and DDI.value) or "Select a config..."

        DDI._clicked = m1 and not DDI._wasM1
        DDI._wasM1   = m1

        self:_Draw(wid.."_ddbg","RoundSquare",{Position=ddPos,Size=ddSz,Color=T.Surface1,ZIndex=6})
        self:_Draw(wid.."_ddb", "RoundSquare",{Position=ddPos,Size=ddSz,Filled=false,Color=isOpen and T.Accent or T.Border0,Thickness=1,ZIndex=7})
        self:_Draw(wid.."_ddv", "Text",{Position=ddPos+Vector2.new(8,5),Text=dispV,Size=13,Font=FONT,Color=DDI.value~="" and T.Text or T.SubText,ZIndex=7})
        self:_Draw(wid.."_ddarr","Text",{Position=ddPos+Vector2.new(innerW-16,5),Text=isOpen and "▲" or "▼",Size=12,Font=FONT,Color=isOpen and T.Accent or T.SubText,ZIndex=7})

        if DDI._clicked and not self._blockClicks then
            if over(ddPos,ddSz) then
                if self._openDropId==DDI._selfId then self._openDropId=nil
                elseif self._openDropId==nil then self._openDropId=DDI._selfId; self._cpTarget=nil end
            elseif isOpen then
                local lH=(math.min(DDI.maxVisible,#DDI.options)*20+4)
                if not over(ddPos+Vector2.new(0,ddSz.Y+2),Vector2.new(innerW,lH)) then
                    self._openDropId=nil
                end
            end
        end

        if isOpen then
            local lH=(math.min(DDI.maxVisible,#DDI.options)*20+4)
            if over(ddPos+Vector2.new(0,ddSz.Y+2),Vector2.new(innerW,lH)) then self._blockClicks=true end
            self._deferredDrop={wid.."_cmdd",DDI,ddPos,ddSz,innerW,FONT,false}
        end

        -- ── Row 2: "Config Name" label ──────────────────────────
        local lblY = wy+46
        self:_Draw(wid.."_namelbl","Text",{Position=Vector2.new(wx,lblY),Text="Config Name",Size=11,Font=FONT,Color=T.SubText,ZIndex=6})

        -- ── Row 3: Name text input ──────────────────────────────
        local tbY   = wy+58; local tbPos=Vector2.new(wx,tbY); local tbSz=Vector2.new(innerW,22)
        local tfoc  = item._textFocused
        local cursor= (tfoc and math.floor(os.clock()*2)%2==0) and "|" or ""
        local disp  = item._nameInput..cursor
        if disp=="" then disp=tfoc and "|" or "Enter config name..." end

        self:_Draw(wid.."_tbbg","RoundSquare",{Position=tbPos,Size=tbSz,Color=T.Surface1,ZIndex=6})
        self:_Draw(wid.."_tbb", "RoundSquare",{Position=tbPos,Size=tbSz,Filled=false,Color=tfoc and T.Accent or T.Border0,Thickness=1,ZIndex=7})
        self:_Draw(wid.."_tbtxt","Text",{Position=tbPos+Vector2.new(7,5),Text=disp,Size=13,Font=FONT,Color=(item._nameInput~="" or tfoc) and T.Text or T.SubText,ZIndex=7})

        if Input.click and not self._blockClicks then
            if over(tbPos,tbSz) then item._textFocused=true
            elseif item._textFocused then item._textFocused=false end
        end

        if item._textFocused then
            for kc=8,122 do if Input:keyClick(kc) then
                if kc==0x08 then
                    item._nameInput=item._nameInput:sub(1,-2)
                elseif kc==0x0D then
                    item._textFocused=false
                elseif kc==0x20 then
                    item._nameInput=item._nameInput.." "
                elseif kc>=0x30 and kc<=0x5A then
                    local ch=KeyNames[kc]; if ch and #ch==1 then
                        local sh=Input:keyHeld(0x10) or Input:keyHeld(0xA0) or Input:keyHeld(0xA1)
                        item._nameInput=item._nameInput..(sh and ch:upper() or ch:lower())
                    end
                end
            end end
        end

        -- ── Row 4 & 5: Action buttons ────────────────────────────
        -- Layout: two columns, two rows
        local bW=(innerW-6)/2; local bH=24
        local bRow1Y=wy+88; local bRow2Y=wy+118

        -- Helper: draw a styled button
        local function drawBtn(bid,bx,by,bw,bh,label,hColor,hBorder,dColor,dBorder,textColor)
            local bp=Vector2.new(bx,by); local bs=Vector2.new(bw,bh)
            local hov=over(bp,bs)
            self:_Draw(bid.."_bg","RoundSquare",{Position=bp,Size=bs,Color=hov and hColor or T.Surface1,ZIndex=6})
            self:_Draw(bid.."_b", "RoundSquare",{Position=bp,Size=bs,Filled=false,Color=hov and hBorder or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(bid.."_t", "Text",{Position=bp+Vector2.new(bw/2,bh/2),Text=label,Size=12,Font=FONT,Color=hov and (textColor or hBorder) or T.Text,Center=true,ZIndex=7})
            return Input.click and not self._blockClicks and hov
        end

        -- [Save] — saves with typed name
        local saveName = (item._nameInput~="" and item._nameInput or (DDI.value~="" and DDI.value or ""))
        local saveLabel = "Save"
        if drawBtn(wid.."_save", wx,        bRow1Y, bW,bH, saveLabel, T.AccentDark,T.Accent,T.Surface1,T.Border0, T.Accent) then
            if saveName~="" then
                local fn = saveName..".json"
                -- Don't overwrite if already exists – use Overwrite for that
                local exists=pcall(readfile, CFG_BASE.."/"..fn)
                if exists then
                    self:Notify("Config exists! Use Overwrite.","Config",3)
                else
                    if self:SaveConfig(fn) then
                        item._cfgList=listSavedConfigs(); DDI.options=item._cfgList
                        DDI.value=saveName
                    end
                end
            else
                self:Notify("Enter a config name first.","Config",3)
            end
        end

        -- [Overwrite] — overwrites selected / typed name
        local owLabel = "Overwrite"
        if drawBtn(wid.."_ow", wx+bW+6,   bRow1Y, bW,bH, owLabel, Color3.fromRGB(50,50,14),Color3.fromRGB(200,180,50),T.Surface1,T.Border0, Color3.fromRGB(220,200,60)) then
            local target = saveName~="" and saveName or DDI.value
            if target~="" then
                local fn=target..".json"
                local exists=pcall(readfile, CFG_BASE.."/"..fn)
                if exists then
                    self:SaveConfig(fn)
                else
                    self:Notify("No config found to overwrite.","Config",3)
                end
            else
                self:Notify("Select or name a config first.","Config",3)
            end
        end

        -- [Delete] — deletes selected config
        if drawBtn(wid.."_del", wx,        bRow2Y, bW,bH, "Delete", T.RedDark,T.Red,T.Surface1,T.Border0, T.Red) then
            local target = DDI.value~="" and DDI.value or saveName
            if target~="" then
                self:DeleteConfig(target..".json")
                item._cfgList=listSavedConfigs(); DDI.options=item._cfgList
                if DDI.value==target then DDI.value=""; item._nameInput="" end
                item._autoload=getAutoloadName()
            else
                self:Notify("Select a config to delete.","Config",3)
            end
        end

        -- [Auto Load] — toggle autoload for selected config
        local isAutoloaded = (item._autoload~="" and item._autoload==(DDI.value~="" and DDI.value or saveName))
        local alLabel = isAutoloaded and "Auto Load: ON" or "Auto Load"
        local alColor1= isAutoloaded and T.GreenDark or T.Surface1
        local alColor2= isAutoloaded and T.Green     or T.Border0
        local alTColor= isAutoloaded and T.Green     or T.Text
        if drawBtn(wid.."_al", wx+bW+6,   bRow2Y, bW,bH, alLabel, alColor1,alColor2,alColor1,alColor2,alTColor) then
            local target = DDI.value~="" and DDI.value or saveName
            if target~="" then
                if isAutoloaded then
                    setAutoloadName(""); item._autoload=""
                    self:Notify("Auto-load cleared.","Config",3)
                else
                    setAutoloadName(target); item._autoload=target
                    self:Notify("Auto-load set: "..target,"Config",3)
                end
            else
                self:Notify("Select a config first.","Config",3)
            end
        end

        -- Auto-load indicator strip at bottom
        if item._autoload~="" then
            local stripY=wy+148
            self:_Draw(wid.."_alstrip","Square",{Position=Vector2.new(wx,stripY-4),Size=Vector2.new(innerW,2),Color=T.Green,ZIndex=6})
            self:_Draw(wid.."_altxt","Text",{Position=Vector2.new(wx,stripY-2),Text="Auto-loading: "..item._autoload,Size=11,Font=FONT,Color=T.Green,ZIndex=6})
        else
            self:_Undraw(wid.."_alstrip"); self:_Undraw(wid.."_altxt")
        end
    end

    -- ── Widget Renderer ──────────────────────────────────────────────────────
    function WIN:_renderWidget(item,wid,wx,wy,innerW,FONT,minY,maxY)
        local wH=getWidgetHeight(item,self)
        if wy+wH<minY or wy>maxY then return wH end

        if item.type=="label" then
            local lines=wrapText(item.label,innerW,13)
            for li,line in ipairs(lines) do
                self:_Draw(wid.."_lbl"..li,"Text",{Position=Vector2.new(wx,wy+(li-1)*16+2),Text=line,Size=13,Font=FONT,Color=T.SubText,ZIndex=6})
            end
            for li=#lines+1,10 do self:_Undraw(wid.."_lbl"..li) end

        elseif item.type=="supporter_label" then
            self:_Draw(wid.."_slbl","Text",{Position=Vector2.new(wx,wy+2),Text=item.text,Size=13,Font=FONT,Color=item.color,ZIndex=6})

        elseif item.type=="toggle" then
            local bsz=Vector2.new(14,14); local bpos=Vector2.new(wx+innerW-14,wy)
            local kbW=0; local kbPos; local kbBadgeW=0
            if item.keybind~=nil then
                local kbStr=item.kb_listening and "[ ... ]" or ("["..keyName(item.keybind).."]")
                kbBadgeW=textW("["..keyName(item.keybind).."]",11)+8
                kbPos=Vector2.new(bpos.X-kbBadgeW-6,wy); kbW=kbBadgeW+6
                self:_Draw(wid.."_kbbg","RoundSquare",{Position=kbPos,Size=Vector2.new(kbBadgeW,14),Color=item.kb_listening and T.AccentDark or T.Surface1,ZIndex=6})
                self:_Draw(wid.."_kbb", "RoundSquare",{Position=kbPos,Size=Vector2.new(kbBadgeW,14),Filled=false,Color=item.kb_listening and T.Accent or T.Border0,Thickness=1,ZIndex=7})
                self:_Draw(wid.."_kbt", "Text",{Position=kbPos+Vector2.new(kbBadgeW/2,7),Text=kbStr,Size=11,Font=FONT,Color=item.kb_listening and T.Accent or T.SubText,Center=true,ZIndex=7})
                local m1=Input.held
                if m1 and not item.kb_wasM1 and not self._blockClicks and over(kbPos,Vector2.new(kbBadgeW,14)) then item.kb_listening=true end
                item.kb_wasM1=m1
                if item.kb_listening then
                    for kc=1,255 do if kc~=0x01 and kc~=0x02 and Input:keyClick(kc) then
                        if kc~=0x1B then item.keybind=kc end; item.kb_listening=false; break
                    end end
                end
                if item.keybind and item.keybind~=0 and not item.kb_listening then
                    if Input:keyClick(item.keybind) then item.value=not item.value; pcall(item.cb,item.value) end
                end
            end
            -- Checkbox with accent fill + border
            self:_Draw(wid.."_box","RoundSquare",{Position=bpos,Size=bsz,Color=item.value and T.Accent or T.Surface1,ZIndex=6})
            self:_Draw(wid.."_boxb","RoundSquare",{Position=bpos,Size=bsz,Filled=false,Color=item.value and T.Accent or T.Border1,Thickness=1,ZIndex=7})
            if item.value then
                -- Checkmark tick (two squares approximation)
                self:_Draw(wid.."_ck1","Square",{Position=bpos+Vector2.new(2,6),Size=Vector2.new(4,4),Color=Color3.new(1,1,1),ZIndex=8})
                self:_Draw(wid.."_ck2","Square",{Position=bpos+Vector2.new(4,3),Size=Vector2.new(8,4),Color=Color3.new(1,1,1),ZIndex=8})
            else
                self:_Undraw(wid.."_ck1"); self:_Undraw(wid.."_ck2")
            end
            self:_Draw(wid.."_lbl","Text",{Position=Vector2.new(wx,wy+1),Text=item.label,Size=13,Font=FONT,Color=item.value and T.Text or T.SubText,ZIndex=6})
            if Input.click and not self._blockClicks and over(Vector2.new(wx,wy),Vector2.new(innerW,16)) then
                local clickedBadge=false
                if item.keybind~=nil and kbPos and over(kbPos,Vector2.new(kbBadgeW,14)) then clickedBadge=true end
                if not clickedBadge then item.value=not item.value; pcall(item.cb,item.value) end
            end

        elseif item.type=="button" then
            local bpos=Vector2.new(wx,wy); local bsz=Vector2.new(innerW,22); local hov=over(bpos,bsz)
            self:_Draw(wid.."_btn","RoundSquare",{Position=bpos,Size=bsz,Color=hov and T.AccentDark or T.Surface1,ZIndex=6})
            self:_Draw(wid.."_btnb","RoundSquare",{Position=bpos,Size=bsz,Filled=false,Color=hov and T.Accent or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_btnt","Text",{Position=bpos+Vector2.new(innerW/2,bsz.Y/2),Text=item.label,Size=13,Font=FONT,Color=hov and T.Accent or T.Text,Center=true,ZIndex=7})
            if Input.click and not self._blockClicks and hov then pcall(item.cb) end

        elseif item.type=="slider" then
            local valStr=tostring(item.value)..item.suffix
            self:_Draw(wid.."_lbl","Text",{Position=Vector2.new(wx,wy),Text=item.label,Size=13,Font=FONT,Color=T.Text,ZIndex=6})
            self:_Draw(wid.."_val","Text",{Position=Vector2.new(wx+innerW-textW(valStr,12)-2,wy),Text=valStr,Size=12,Font=FONT,Color=T.Accent,ZIndex=6})
            local trkPos=Vector2.new(wx,wy+17); local trkSz=Vector2.new(innerW,5)
            self:_Draw(wid.."_trk","Square",{Position=trkPos,Size=trkSz,Color=T.Surface1,ZIndex=6})
            local pct=clamp((item.value-item.min)/(item.max-item.min),0,1); local fillW=math.max(4,trkSz.X*pct)
            self:_Draw(wid.."_fill","Square",{Position=trkPos,Size=Vector2.new(fillW,trkSz.Y),Color=T.Accent,ZIndex=7})
            -- Glowing knob
            self:_Draw(wid.."_knob","RoundSquare",{Position=Vector2.new(trkPos.X+fillW-5,trkPos.Y-4),Size=Vector2.new(10,13),Color=T.Text,ZIndex=8})
            self:_Draw(wid.."_knobb","RoundSquare",{Position=Vector2.new(trkPos.X+fillW-5,trkPos.Y-4),Size=Vector2.new(10,13),Filled=false,Color=T.Accent,Thickness=1,ZIndex=9})
            if Input.click and not self._blockClicks and over(trkPos-Vector2.new(0,5),trkSz+Vector2.new(0,12)) then self._sliderDrag=item end
            if self._sliderDrag==item then
                if Input.held then
                    local p=clamp((mpos().X-trkPos.X)/trkSz.X,0,1)
                    item.value=clamp(math.floor(item.min+(item.max-item.min)*p+0.5),item.min,item.max)
                    pcall(item.cb,item.value)
                else self._sliderDrag=nil end
            end

        elseif item.type=="dropdown" then
            if not item._selfId then item._selfId={}; item._wasM1=false end
            local m1=Input.held; item._clicked=m1 and not item._wasM1
            local ddPos=Vector2.new(wx,wy+14); local ddSz=Vector2.new(innerW,22)
            local isOpen=(self._openDropId==item._selfId)
            local listH=(math.min(item.maxVisible,#item.options)*20+4)
            local listPos=ddPos+Vector2.new(0,ddSz.Y+2)

            self:_Draw(wid.."_ddlbl","Text",{Position=Vector2.new(wx,wy),Text=item.label,Size=11,Font=FONT,Color=T.SubText,ZIndex=6})
            self:_Draw(wid.."_ddbg","RoundSquare",{Position=ddPos,Size=ddSz,Color=T.Surface1,ZIndex=6})
            self:_Draw(wid.."_ddb","RoundSquare",{Position=ddPos,Size=ddSz,Filled=false,Color=isOpen and T.Accent or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_ddval","Text",{Position=ddPos+Vector2.new(8,5),Text=item.value,Size=13,Font=FONT,Color=T.Text,ZIndex=7})
            self:_Draw(wid.."_ddarr","Text",{Position=ddPos+Vector2.new(innerW-14,5),Text=isOpen and "▲" or "▼",Size=11,Font=FONT,Color=isOpen and T.Accent or T.SubText,ZIndex=7})

            if item._clicked and not self._blockClicks then
                if over(ddPos,ddSz) then
                    if self._openDropId==item._selfId then self._openDropId=nil
                    elseif self._openDropId==nil then self._openDropId=item._selfId; self._cpTarget=nil end
                elseif isOpen and not over(listPos,Vector2.new(innerW,listH)) then self._openDropId=nil end
            end
            if isOpen then
                if over(listPos,Vector2.new(innerW,listH)) then self._blockClicks=true end
                self._deferredDrop={wid,item,ddPos,ddSz,innerW,FONT,false}
            end
            item._wasM1=m1

        elseif item.type=="multidropdown" then
            if not item._selfId then item._selfId={}; item._wasM1=false end
            local m1=Input.held; item._clicked=m1 and not item._wasM1
            local ddPos=Vector2.new(wx,wy+14); local ddSz=Vector2.new(innerW,22)
            local isOpen=(self._openDropId==item._selfId)
            local listH=(math.min(item.maxVisible,#item.options)*20+4)
            local listPos=ddPos+Vector2.new(0,ddSz.Y+2)
            local selList={}; for _,o in ipairs(item.options) do if item.selected[o] then selList[#selList+1]=o end end
            local dispStr=#selList==0 and "None" or (#selList.."/"..(#item.options).." selected")

            self:_Draw(wid.."_ddlbl","Text",{Position=Vector2.new(wx,wy),Text=item.label,Size=11,Font=FONT,Color=T.SubText,ZIndex=6})
            self:_Draw(wid.."_ddbg","RoundSquare",{Position=ddPos,Size=ddSz,Color=T.Surface1,ZIndex=6})
            self:_Draw(wid.."_ddb","RoundSquare",{Position=ddPos,Size=ddSz,Filled=false,Color=isOpen and T.Accent or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_ddval","Text",{Position=ddPos+Vector2.new(8,5),Text=dispStr,Size=13,Font=FONT,Color=T.Text,ZIndex=7})
            self:_Draw(wid.."_ddarr","Text",{Position=ddPos+Vector2.new(innerW-14,5),Text=isOpen and "▲" or "▼",Size=11,Font=FONT,Color=isOpen and T.Accent or T.SubText,ZIndex=7})

            if item._clicked and not self._blockClicks then
                if over(ddPos,ddSz) then
                    if self._openDropId==item._selfId then self._openDropId=nil
                    elseif self._openDropId==nil then self._openDropId=item._selfId; self._cpTarget=nil end
                elseif isOpen and not over(listPos,Vector2.new(innerW,listH)) then self._openDropId=nil end
            end
            if isOpen then
                if over(listPos,Vector2.new(innerW,listH)) then self._blockClicks=true end
                self._deferredDrop={wid,item,ddPos,ddSz,innerW,FONT,true}
            end
            item._wasM1=m1

        elseif item.type=="colorpicker" then
            if not item._wasM1 then item._wasM1=false end
            local m1=Input.held; item._clicked=m1 and not item._wasM1
            local swPos=Vector2.new(wx,wy); local swSz=Vector2.new(innerW,18)
            -- Color swatch
            self:_Draw(wid.."_sw","RoundSquare",{Position=swPos,Size=Vector2.new(20,18),Color=item.value,ZIndex=6})
            self:_Draw(wid.."_swb","RoundSquare",{Position=swPos,Size=Vector2.new(20,18),Filled=false,Color=T.Border1,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_lbl","Text",{Position=swPos+Vector2.new(26,3),Text=item.label,Size=13,Font=FONT,Color=T.Text,ZIndex=6})
            local isOpen=(self._cpTarget==item)
            local cpTotalPos=Vector2.new(wx,wy+24)-Vector2.new(4,4); local cpTotalSz=Vector2.new(innerW+8,118)
            if item._clicked and not self._blockClicks then
                if over(swPos,swSz) then
                    if isOpen then self._cpTarget=nil else self._cpTarget=item; self._openDropId=nil end
                elseif isOpen and not over(cpTotalPos,cpTotalSz) then self._cpTarget=nil end
            end
            if self._cpTarget==item then
                if over(cpTotalPos,cpTotalSz) then self._blockClicks=true end
                self._deferredCP={wid,item,wx,wy,innerW,FONT}
            end
            item._wasM1=m1

        elseif item.type=="keybind" then
            local kbStr=item.listening and "[ ... ]" or ("[ "..keyName(item.value).." ]")
            local kbW=textW("[ "..keyName(item.value).." ]",12)+10
            local kbPos=Vector2.new(wx+innerW-kbW,wy); local kbSz=Vector2.new(kbW,18)
            self:_Draw(wid.."_lbl","Text",{Position=Vector2.new(wx,wy+2),Text=item.label,Size=13,Font=FONT,Color=T.Text,ZIndex=6})
            self:_Draw(wid.."_kbbg","RoundSquare",{Position=kbPos,Size=kbSz,Color=item.listening and T.AccentDark or T.Surface1,ZIndex=6})
            self:_Draw(wid.."_kbb","RoundSquare",{Position=kbPos,Size=kbSz,Filled=false,Color=item.listening and T.Accent or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_kbtxt","Text",{Position=kbPos+Vector2.new(kbSz.X/2,kbSz.Y/2),Text=kbStr,Size=12,Font=FONT,Color=item.listening and T.Accent or T.SubText,Center=true,ZIndex=7})
            if Input.click and not self._blockClicks and over(kbPos,kbSz) then item.listening=true; self._keybindTarget=item end
            if item.listening and self._keybindTarget==item then
                for kc=1,255 do if kc~=0x01 and kc~=0x02 and Input:keyClick(kc) then
                    if kc~=0x1B then item.value=kc; pcall(item.cb,kc) end
                    item.listening=false; self._keybindTarget=nil; break
                end end
            end

        elseif item.type=="textbox" then
            local tbPos=Vector2.new(wx,wy+15); local tbSz=Vector2.new(innerW,22)
            local focused=(self._textboxTarget==item)
            local cursor=(focused and math.floor(os.clock()*2)%2==0) and "|" or ""
            local display=item.value..cursor
            if display=="" then display=focused and "|" or item.label end
            self:_Draw(wid.."_lbl","Text",{Position=Vector2.new(wx,wy),Text=item.label,Size=11,Font=FONT,Color=T.SubText,ZIndex=6})
            self:_Draw(wid.."_tbbg","RoundSquare",{Position=tbPos,Size=tbSz,Color=T.Surface1,ZIndex=6})
            self:_Draw(wid.."_tbb","RoundSquare",{Position=tbPos,Size=tbSz,Filled=false,Color=focused and T.Accent or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_tbtxt","Text",{Position=tbPos+Vector2.new(7,5),Text=display,Size=13,Font=FONT,Color=(item.value~="" or focused) and T.Text or T.SubText,ZIndex=7})
            if Input.click and not self._blockClicks then
                if over(tbPos,tbSz) then self._textboxTarget=item
                elseif self._textboxTarget==item then self._textboxTarget=nil end
            end
            if focused then
                for kc=8,122 do if Input:keyClick(kc) then
                    if kc==0x08 then item.value=item.value:sub(1,-2); pcall(item.cb,item.value)
                    elseif kc==0x0D then self._textboxTarget=nil
                    elseif kc==0x20 then item.value=item.value.." "; pcall(item.cb,item.value)
                    elseif kc>=0x30 and kc<=0x5A then
                        local ch=KeyNames[kc]; if ch and #ch==1 then
                            local sh=Input:keyHeld(0x10) or Input:keyHeld(0xA0) or Input:keyHeld(0xA1)
                            item.value=item.value..(sh and ch:upper() or ch:lower()); pcall(item.cb,item.value)
                        end
                    end
                end end
            end

        elseif item.type=="settings_keybind" then
            local kbStr=item.listening and "[ ... ]" or ("[ "..keyName(self.MenuKey).." ]")
            local kbW=textW("[ "..keyName(self.MenuKey).." ]",12)+10
            local kbPos=Vector2.new(wx+innerW-kbW,wy); local kbSz=Vector2.new(kbW,18)
            self:_Draw(wid.."_lbl","Text",{Position=Vector2.new(wx,wy+2),Text=item.label,Size=13,Font=FONT,Color=T.Text,ZIndex=6})
            self:_Draw(wid.."_kbbg","RoundSquare",{Position=kbPos,Size=kbSz,Color=item.listening and T.AccentDark or T.Surface1,ZIndex=6})
            self:_Draw(wid.."_kbb","RoundSquare",{Position=kbPos,Size=kbSz,Filled=false,Color=item.listening and T.Accent or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_kbtxt","Text",{Position=kbPos+Vector2.new(kbSz.X/2,kbSz.Y/2),Text=kbStr,Size=12,Font=FONT,Color=item.listening and T.Accent or T.SubText,Center=true,ZIndex=7})
            if Input.click and not self._blockClicks and over(kbPos,kbSz) then item.listening=true; self._settingsListen=true end
            if item.listening and self._settingsListen then
                for kc=1,255 do if kc~=0x01 and kc~=0x02 and Input:keyClick(kc) then
                    if kc~=0x1B then self.MenuKey=kc; self:SaveSettings(); self:Notify("Key: "..keyName(kc),self.Title,3) end
                    item.listening=false; self._settingsListen=false; break
                end end
            end

        elseif item.type=="settings_toggle" then
            local bsz=Vector2.new(14,14); local bpos=Vector2.new(wx+innerW-14,wy)
            self:_Draw(wid.."_box","RoundSquare",{Position=bpos,Size=bsz,Color=item.value and T.Accent or T.Surface1,ZIndex=6})
            self:_Draw(wid.."_boxb","RoundSquare",{Position=bpos,Size=bsz,Filled=false,Color=item.value and T.Accent or T.Border1,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_lbl","Text",{Position=Vector2.new(wx,wy+1),Text=item.label,Size=13,Font=FONT,Color=item.value and T.Text or T.SubText,ZIndex=6})
            if Input.click and not self._blockClicks and over(Vector2.new(wx,wy),Vector2.new(innerW,16)) then
                item.value=not item.value
                if item.label=="Start Minimized" then self._startMinimized=item.value
                elseif item.label=="Block Inputs" then self._blockInputsEnabled=item.value; if not item.value then setrobloxinput(true) end end
                self:SaveSettings()
            end

        elseif item.type=="settings_kill" then
            local bpos=Vector2.new(wx,wy); local bsz=Vector2.new(innerW,22); local hov=over(bpos,bsz)
            self:_Draw(wid.."_btn","RoundSquare",{Position=bpos,Size=bsz,Color=hov and T.RedDark or T.Surface1,ZIndex=6})
            self:_Draw(wid.."_btnb","RoundSquare",{Position=bpos,Size=bsz,Filled=false,Color=hov and T.Red or T.Border0,Thickness=1,ZIndex=7})
            self:_Draw(wid.."_btnt","Text",{Position=bpos+Vector2.new(innerW/2,bsz.Y/2),Text=item.label,Size=13,Font=FONT,Color=T.Red,Center=true,ZIndex=7})
            if Input.click and not self._blockClicks and hov then self:Notify("Script killed.",self.Title,2); self._running=false end

        elseif item.type=="config_manager" then
            self:_renderConfigManager(item,wid,wx,wy,innerW,FONT)
        end

        return wH
    end

    -- ── Main Render ──────────────────────────────────────────────────────────
    function WIN:_render()
        local pos=self._pos; local sz=self.Size; local t=os.clock(); local FONT=CurrentFont
        self._blockClicks=false; self._deferredDrop=nil; self._deferredCP=nil

        if not self._open then
            self:_UndrawStartsWith("m_")
            for i=1,self._snakeCount do self._snakeLines[i].Visible=false end
            return
        end

        self:_BeginFrame()

        -- ── Drag ────────────────────────────────────────────────
        if Input.click and over(pos,Vector2.new(sz.X,38)) and not self._drag then self._drag=mpos()-pos end
        if not Input.held then self._drag=nil end
        if self._drag then self._pos=mpos()-self._drag; pos=self._pos end

        -- ── Window chrome ────────────────────────────────────────
        local topH=38

        -- Outer shadow (3-layer fake shadow via larger boxes)
        self:_Draw("m_sh3","Square",{Position=pos-Vector2.new(3,3),Size=sz+Vector2.new(6,6),Color=Color3.new(0,0,0),Transparency=0.12,ZIndex=0})
        self:_Draw("m_sh2","Square",{Position=pos-Vector2.new(2,2),Size=sz+Vector2.new(4,4),Color=Color3.new(0,0,0),Transparency=0.18,ZIndex=0})
        self:_Draw("m_sh1","Square",{Position=pos-Vector2.new(1,1),Size=sz+Vector2.new(2,2),Color=Color3.new(0,0,0),Transparency=0.30,ZIndex=0})

        -- Window body
        self:_Draw("m_bg","Square",{Position=pos,Size=sz,Color=T.Body,ZIndex=1})
        self:_Draw("m_b", "Square",{Position=pos,Size=sz,Filled=false,Color=T.Border0,Thickness=1,ZIndex=2})

        -- Header bar
        self:_Draw("m_top_bg",  "Square",{Position=pos,Size=Vector2.new(sz.X,topH),Color=T.Surface0,ZIndex=2})
        self:_Draw("m_top_b",   "Square",{Position=pos,Size=Vector2.new(sz.X,topH),Filled=false,Color=T.Border0,Thickness=1,ZIndex=3})
        -- Accent underline on header
        self:_Draw("m_top_line","Square",{Position=pos+Vector2.new(0,topH-2),Size=Vector2.new(sz.X,2),Color=T.Accent,ZIndex=3})
        -- Title
        self:_Draw("m_top_title","Text",{Position=pos+Vector2.new(12,10),Text=self.Title,Size=16,Font=FONT,Color=T.Accent,ZIndex=3})

        -- Watermark pill
        local wmStr=self.Title.."   "..keyName(self.MenuKey).." to toggle"
        local wmW=textW(wmStr,11)+16
        self:_Draw("m_wm_bg","Square",{Position=pos-Vector2.new(0,21),Size=Vector2.new(wmW,17),Color=T.Surface0,ZIndex=1})
        self:_Draw("m_wm_b", "Square",{Position=pos-Vector2.new(0,21),Size=Vector2.new(wmW,17),Filled=false,Color=T.Border0,Thickness=1,ZIndex=2})
        self:_Draw("m_wm_txt","Text",{Position=pos-Vector2.new(-8,17),Text=wmStr,Size=11,Font=FONT,Color=T.SubText,ZIndex=2})

        -- ── Snake border animation ───────────────────────────────
        local snkPos=pos+Vector2.new(0,topH+2); local snkSz=sz-Vector2.new(0,topH+2)
        for i=1,self._snakeCount do
            local ti=t*0.175-i*0.004; local sl=self._snakeLines[i]
            sl.From=pointOnRect(ti,snkPos,snkSz)
            sl.To  =pointOnRect(ti+0.004,snkPos,snkSz)
            sl.Color=Color3.fromHSV((t*0.12+i*0.05)%1,0.75,1)
            sl.Transparency=(1-i/self._snakeCount)*0.78
            sl.Visible=true; sl.ZIndex=50
        end

        -- ── Dynamic width ────────────────────────────────────────
        local neededW=10
        for _,tab in ipairs(self._tabs) do neededW=neededW+textW(tab._name,13)+24+5 end
        neededW=neededW+5
        if neededW>self._minSize.X then
            self.Size=Vector2.new(neededW,self.Size.Y); sz=self.Size
        elseif self.Size.X~=self._minSize.X then
            self.Size=Vector2.new(self._minSize.X,self.Size.Y); sz=self.Size
        end

        -- ── Tab buttons ──────────────────────────────────────────
        local tabY=topH+4; local tabH=26; local tabX=10
        for i,tab in ipairs(self._tabs) do
            local tw=textW(tab._name,13)+24
            local tpos=pos+Vector2.new(tabX,tabY); local tsz=Vector2.new(tw,tabH)
            local isOpen=(self._openTab==tab)
            self:_Draw("m_tab_bg_"..i,"Square",{Position=tpos,Size=tsz,Color=isOpen and T.Surface1 or T.Surface0,ZIndex=13})
            self:_Draw("m_tab_b_"..i, "Square",{Position=tpos,Size=tsz,Filled=false,Color=isOpen and T.Accent or T.Border0,Thickness=1,ZIndex=14})
            self:_Draw("m_tab_txt_"..i,"Text",{Position=tpos+Vector2.new(tw/2,tabH/2),Text=tab._name,Size=13,Font=FONT,Color=isOpen and T.Text or T.SubText,Center=true,ZIndex=14})
            if isOpen then
                self:_Draw("m_tab_ul_"..i,"Square",{Position=tpos+Vector2.new(0,tabH-2),Size=Vector2.new(tw,2),Color=T.Accent,ZIndex=15})
            else self:_Undraw("m_tab_ul_"..i) end
            if Input.click and over(tpos,tsz) and self._openTab~=tab then
                self._openTab=tab; self._openDropId=nil; self._textboxTarget=nil; self._cpTarget=nil
                self:_UndrawStartsWith("m_sec_")
            end
            tabX=tabX+tw+5
        end

        if not self._openTab then self:_FlushFrame(); return end

        -- ── Section content ──────────────────────────────────────
        local contTop=topH+tabH+10; local padX=10
        local colW=(sz.X-padX*3)/2; local colYL=0; local colYR=0
        local minViewY=contTop; local maxViewY=sz.Y-10

        for si,sec in ipairs(self._openTab._sections) do
            local isLeft=(si%2==1)
            local sx=isLeft and padX or (padX*2+colW)
            local sy=isLeft and colYL or colYR
            local sid="m_sec_"..si

            -- Compute section content height
            local secH=20+8  -- header + bottom pad
            for _,item in ipairs(sec._widgets) do secH=secH+getWidgetHeight(item,self)+6 end

            local renderY=pos.Y+contTop+sy-self._openTab.scroll
            local secTopY=math.max(renderY,pos.Y+minViewY)
            local secBotY=math.min(renderY+secH,pos.Y+maxViewY)
            local clampedH=secBotY-secTopY

            if clampedH>0 then
                self:_Draw(sid.."_bg","Square",{Position=Vector2.new(pos.X+sx,secTopY),Size=Vector2.new(colW,clampedH),Color=T.Surface0,ZIndex=4})
                self:_Draw(sid.."_bgb","Square",{Position=Vector2.new(pos.X+sx,secTopY),Size=Vector2.new(colW,clampedH),Filled=false,Color=T.Border0,Thickness=1,ZIndex=5})
                -- Left accent bar on section
                self:_Draw(sid.."_acl","Square",{Position=Vector2.new(pos.X+sx,secTopY),Size=Vector2.new(2,math.min(clampedH,4)),Color=T.Accent,ZIndex=6})
            else self:_Undraw(sid.."_bg"); self:_Undraw(sid.."_bgb"); self:_Undraw(sid.."_acl") end

            if renderY+14>=pos.Y+minViewY and renderY<pos.Y+maxViewY then
                -- Section accent bar (full height when not clipped at top)
                local acH=math.min(secH,math.max(0,pos.Y+maxViewY-renderY))
                self:_Draw(sid.."_acbar","Square",{Position=Vector2.new(pos.X+sx,renderY),Size=Vector2.new(2,acH),Color=T.Accent,ZIndex=6})
                self:_Draw(sid.."_hdr","Text",{Position=Vector2.new(pos.X+sx+8,renderY+4),Text=sec._name:upper(),Size=10,Font=FONT,Color=T.Accent,ZIndex=6})
            else self:_Undraw(sid.."_acbar"); self:_Undraw(sid.."_hdr") end

            local wY=renderY+20; local innerX=pos.X+sx+8; local innerW=colW-16
            for wi,item in ipairs(sec._widgets) do
                local consumed=self:_renderWidget(item,sid.."_w"..wi,innerX,wY,innerW,FONT,pos.Y+minViewY,pos.Y+maxViewY)
                wY=wY+consumed+6
            end

            if isLeft then colYL=colYL+secH+12 else colYR=colYR+secH+12 end
        end

        -- ── Scroll bar ───────────────────────────────────────────
        local totalH=math.max(colYL,colYR)
        self._openTab.maxScroll=math.max(0,totalH-(maxViewY-minViewY))
        if not self._openDropId and not self._cpTarget then
            if Input.scrollUp   then self._openTab.scroll=math.max(0,self._openTab.scroll-30) end
            if Input.scrollDown then self._openTab.scroll=math.min(self._openTab.maxScroll,self._openTab.scroll+30) end
        end

        if self._openTab.maxScroll>0 then
            local sbW=4; local sbH=maxViewY-minViewY
            local sbX=pos.X+sz.X-sbW-2; local sbY=pos.Y+minViewY
            self:_Draw("m_sb_trk","Square",{Position=Vector2.new(sbX,sbY),Size=Vector2.new(sbW,sbH),Color=T.Surface1,ZIndex=15})
            local thumbH=math.max(20,sbH*(sbH/(sbH+self._openTab.maxScroll)))
            local thumbY=sbY+(sbH-thumbH)*(self._openTab.scroll/self._openTab.maxScroll)
            local sbHov=over(Vector2.new(sbX-2,thumbY),Vector2.new(sbW+4,thumbH))
            if Input.click and not self._blockClicks and sbHov then
                self._dragTabScroll=true; self._dragTabStartY=mpos().Y; self._dragTabStartScroll=self._openTab.scroll
            end
            if not Input.held then self._dragTabScroll=false end
            if self._dragTabScroll then
                local dy=mpos().Y-self._dragTabStartY
                local ratio=self._openTab.maxScroll/(sbH-thumbH)
                self._openTab.scroll=clamp(self._dragTabStartScroll+dy*ratio,0,self._openTab.maxScroll)
            end
            self:_Draw("m_sb_thumb","Square",{Position=Vector2.new(sbX,thumbY),Size=Vector2.new(sbW,thumbH),Color=(sbHov or self._dragTabScroll) and T.Text or T.Accent,ZIndex=16})
        else self:_Undraw("m_sb_trk"); self:_Undraw("m_sb_thumb") end

        -- ── Deferred popups (rendered last so they sit on top) ───
        if self._deferredDrop then self:_renderDDList(table.unpack(self._deferredDrop)) end
        if self._deferredCP   then self:_renderColorPicker(table.unpack(self._deferredCP)) end

        self:_FlushFrame()
    end

    -- ── Main Loop ────────────────────────────────────────────────────────────
    task.spawn(function()
        WIN:_buildInfoTab()
        WIN:_buildSettings()
        task.wait(0.2)
        WIN:LoadSettings()

        -- Auto-load config on startup
        ensureFolders()
        local autoName=getAutoloadName()
        if autoName~="" then
            local fn=autoName..".json"
            WIN:LoadConfig(fn, false)   -- notify the user it auto-loaded
        end

        while WIN._running do
            task.wait()
            Input:update()

            if Input:keyClick(WIN.MenuKey) then
                WIN._open=not WIN._open
                if WIN._blockInputsEnabled then
                    if WIN._open then pcall(setrobloxinput,false)
                    else             pcall(setrobloxinput,true)  end
                end
                if not WIN._open then
                    WIN._openDropId=nil; WIN._textboxTarget=nil
                    WIN._keybindTarget=nil; WIN._settingsListen=false; WIN._cpTarget=nil
                end
            end

            WIN:_render()
        end

        WIN:_DestroyAll()
        for i=1,WIN._snakeCount do WIN._snakeLines[i]:Remove() end
    end)

    return WIN
end

return GalaxLib
