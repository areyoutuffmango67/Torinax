        table.insert(self._tabs,1,ITAB)
        if self._openTab==nil or self._openTab==self._tabs[2] then self._openTab=ITAB end
    end

    function WIN:Notify(msg,title,dur) notify(msg,title or self.Title,dur or 3) end
